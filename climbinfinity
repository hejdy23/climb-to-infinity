-- AUTO DELETE SETTINGS
local AutoDeleteSettings = {
    Common = false,
    Uncommon = false,
    Rare = false
}

-- PET NAME MAPPING (CORRECT SERVER FORMAT)
local PetsByRarity = {
    Common = { "Virus Bunny" },
    Uncommon = { "Zombie Bear" },
    Rare = { "Zombie Dragon" }
}

local function buildDeleteTable()
    local t = {}

    if AutoDeleteSettings.Common then
        for _, pet in ipairs(PetsByRarity.Common) do
            table.insert(t, pet)
        end
    end

    if AutoDeleteSettings.Uncommon then
        for _, pet in ipairs(PetsByRarity.Uncommon) do
            table.insert(t, pet)
        end
    end

    if AutoDeleteSettings.Rare then
        for _, pet in ipairs(PetsByRarity.Rare) do
            table.insert(t, pet)
        end
    end

    return t
end

