--// LOOP STATES
local loopingCoins = false
local loopingRebirth = false
local loopingEggs = false

--// COIN LOOP
local function coinLoop()
	while loopingCoins do
		local args = {
			[1] = "Win",
			[2] = "Increment",
			[3] = 8,
			[4] = 12
		}
		game:GetService("ReplicatedStorage").Events.InvokeServerAction:InvokeServer(unpack(args))
		task.wait(0.1)
	end
end

--// REBIRTH LOOP
local function rebirthLoop()
	while loopingRebirth do
		local args = {
			[1] = "Rebirths",
			[2] = "Request"
		}
		game:GetService("ReplicatedStorage").Events.InvokeServerAction:InvokeServer(unpack(args))
		task.wait(0.05)
	end
end

--// EGG LOOP
local function eggLoop()
	while loopingEggs do
		local args = {
			[1] = "Eggs",
			[2] = "RequestPurchase",
			[3] = {
				["EggName"] = "Zombie",
				["PetsToAutoDelete"] = buildDeleteTable(),
				["EggAmount"] = "max"
			}
		}
		game:GetService("ReplicatedStorage").Events.InvokeServerAction:InvokeServer(unpack(args))
		task.wait(0.2)
	end
end

